-- ══ SANDBOX EXECUTOR ═════════════════════════════
local function safeExec(code)
    local env = {
        print=print,warn=warn,wait=task.wait,task=task,math=math,table=table,
        string=string,os=os,ipairs=ipairs,pairs=pairs,next=next,select=select,
        tonumber=tonumber,tostring=tostring,type=type,pcall=pcall,xpcall=xpcall,
        error=error,rawget=rawget,rawset=rawset,rawequal=rawequal,
        unpack=unpack or table.unpack,coroutine=coroutine,
        Vector3=Vector3,Vector2=Vector2,CFrame=CFrame,Color3=Color3,
        UDim2=UDim2,UDim=UDim,BrickColor=BrickColor,TweenInfo=TweenInfo,
        Enum=Enum,Instance=Instance,game=game,workspace=workspace,script=script,
        Player=Player,
        Character=function() return Player.Character end,
        Humanoid=function() return Player.Character and Player.Character:FindFirstChildOfClass("Humanoid") end,
        RootPart=function() return Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") end,
    }
    env._ENV=env
    local fn,err=loadstring(code)
    if not fn then return false,"Syntax: "..tostring(err) end
    setfenv(fn,env)
    local ok,runErr=pcall(fn)
    if not ok then return false,"Runtime: "..tostring(runErr) end
    return true,"Ran successfully ✓"
end

-- ══ GROQ API ══════════════════════════════════════
local function callGroq(prompt,history)
    local messages={{role="system",content=N.SYSTEM_PROMPT}}
    local startIdx=math.max(1,#history-8)
    for i=startIdx,#history do
        local h=history[i]
        if h.role=="user" or h.role=="ai" then
            table.insert(messages,{role=h.role=="ai" and "assistant" or "user",content=tostring(h.text or "")})
        end
    end
    table.insert(messages,{role="user",content=prompt})
    local body=HttpService:JSONEncode({model=N.MODEL,max_tokens=N.MAX_TOKENS,temperature=0.4,messages=messages})
    local httpReq=(typeof(http_request)=="function" and http_request) or (syn and syn.request) or (http and http.request) or (typeof(request)=="function" and request) or function(o) return HttpService:RequestAsync(o) end
    local resp=httpReq({Url="https://api.groq.com/openai/v1/chat/completions",Method="POST",Headers={["Content-Type"]="application/json",["Authorization"]="Bearer "..N.API_KEY},Body=body})
    local sc=tonumber(resp.StatusCode) or 200
    if sc<200 or sc>=300 then error("HTTP "..tostring(resp.StatusCode).." — "..tostring(resp.StatusMessage or "")) end
    local outer=HttpService:JSONDecode(resp.Body)
    if not outer or not outer.choices or not outer.choices[1] then error("Empty response") end
    local text=outer.choices[1].message.content or ""
    text=text:gsub("```json",""):gsub("```lua",""):gsub("```",""):match("^%s*(.-)%s*$")
    local ok,parsed=pcall(HttpService.JSONDecode,HttpService,text)
    if ok and type(parsed)=="table" then return {message=tostring(parsed.message or "Here you go!"),code=tostring(parsed.code or "")} end
    return {message=text,code=""}
end

