    {tag="SPAWN",col=T.H_FG,kws={"spawn","give","tool","weapon","sword","gun","item"}},
    {tag="DATA",col=Color3.fromRGB(100,200,255),kws={"data","save","load","store","profile","stats"}},
    {tag="GAMESTATE",col=T.H_WARN,kws={"start","win","reset","restart","round","intermission"}},
}
local function getTags(r)
    local tags={}; local name=r.Name:lower()
    for _,cat in ipairs(EXPLOIT_CATS) do for _,kw in ipairs(cat.kws) do if name:find(kw) then table.insert(tags,cat); break end end end
    return tags
end

