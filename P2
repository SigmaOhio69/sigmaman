-- 1. Part Orbital Nuke — launches all unanchored parts at players
local OrbNukeBtn=hBtn("☄️  Part Orbital Nuke",T.H_RED,"Fires every unanchored part in workspace at every player like missiles")
OrbNukeBtn.MouseButton1Click:Connect(function()
    termPrint("> LAUNCHING ORBITAL NUKE...",T.H_RED)
    local parts=allUnanchored(); local plrs=Players:GetPlayers()
    if #parts==0 then termPrint("> No unanchored parts found",T.H_DIM) return end
    local count=0
    for _,part in ipairs(parts) do
        task.spawn(function()
            pcall(function()
                -- pick a random player to target
                local target=plrs[math.random(1,#plrs)]
                local tRoot=target.Character and target.Character:FindFirstChild("HumanoidRootPart")
