local SKIP_KWS={"teleportservice","joinserver","joinplace","serverhop","teleporttoplace","joingame","switchserver","teleportasync"}
local function isTP(r)
    local n=r.Name:lower(); for _,kw in ipairs(SKIP_KWS) do if n:find(kw) then return true end end
    local path=r:GetFullName():lower(); return path:find("teleport") and (path:find("place") or path:find("server") or path:find("join"))
end

local EXPLOIT_CATS={
    {tag="FLING",col=T.H_WARN,kws={"fling","launch","throw","ragdoll","knockback","yeet","push"}},
    {tag="KILL",col=T.H_RED,kws={"kill","die","damage","hurt","eliminate","slay"}},
