-- ══ SEND MESSAGE ══════════════════════════════════
local function sendMessage(prompt)
    prompt=prompt:match("^%s*(.-)%s*$"); if prompt=="" or N.isThinking then return end
    local now=tick(); if now-N.lastReq<N.COOLDOWN then bubble("system",("⏳ Wait %ds"):format(math.ceil(N.COOLDOWN-(now-N.lastReq)))); return end
    N.lastReq=now
    if N.API_KEY=="YOUR_GROQ_KEY_HERE" then bubble("system","⚠ Add your Groq API key at the top of Part 1.\nGet one free at console.groq.com"); return end
    N.isThinking=true; hideCode(); table.insert(N.chatHistory,{role="user",text=prompt}); bubble("user",prompt)
    tw(N.StatLabel,{TextColor3=T.WARNING},.15); tw(N.StatBadge,{BackgroundColor3=T.WARN_D},.15); N.StatLabel.Text="● thinking"; startThinking()
    task.spawn(function()
        local ok,result=pcall(callGroq,prompt,N.chatHistory)
        stopThinking(); tw(N.StatLabel,{TextColor3=T.SUCCESS},.15); tw(N.StatBadge,{BackgroundColor3=T.SUCC_D},.15); N.StatLabel.Text="● ready"; N.isThinking=false
        if not ok then bubble("system","⚠ API error — "..tostring(result):sub(1,160)); return end
        local msg=result.message or "Here you go!"; local code=result.code or ""
        table.insert(N.chatHistory,{role="ai",text=msg,code=code}); bubble("ai",msg)
        if code~="" then showCode(code) end
    end)
end

