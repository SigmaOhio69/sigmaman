local dupe2On=false
local Dupe2Btn=hBtn("🔄  Dupe Tools — Method 2 (Drop+Respawn Loop)",T.SUCCESS,"Drops tools to workspace, force respawns, walks over them — loops")
Dupe2Btn.MouseButton1Click:Connect(function()
    dupe2On=not dupe2On
    if not dupe2On then Dupe2Btn.Text="🔄  Dupe Tools — Method 2 (Drop+Respawn Loop)"; termPrint("> Dupe loop stopped"); return end
    Dupe2Btn.Text="■ Stop Dupe Loop"
    termPrint("> DUPE LOOP STARTED",T.SUCCESS)
    task.spawn(function()
        while dupe2On do
            local bp=Player:FindFirstChild("Backpack"); local char=Player.Character
            local dropped={}
            -- drop all tools
            if bp then for _,t in ipairs(bp:GetChildren()) do if t:IsA("Tool") then
                pcall(function()
                    local root=char and char:FindFirstChild("HumanoidRootPart")
                    local pos=root and root.Position+Vector3.new(math.random(-5,5),0,math.random(-5,5)) or Vector3.new(0,5,0)
                    t.Parent=workspace
                    if t:FindFirstChild("Handle") then t.Handle.CFrame=CFrame.new(pos) end
                    table.insert(dropped,t)
                end)
            end end end
            if char then for _,t in ipairs(char:GetChildren()) do if t:IsA("Tool") then
                pcall(function() t.Parent=workspace; table.insert(dropped,t) end)
            end end end
            if #dropped==0 then termPrint("> No tools",T.H_RED); dupe2On=false; Dupe2Btn.Text="🔄  Dupe Tools — Method 2 (Drop+Respawn Loop)"; return end
            task.wait(.05)
            pcall(function() Player:LoadCharacter() end)
            task.wait(1.5)
            -- pick up by walking root onto each dropped tool
            local newChar=Player.Character; local newRoot=newChar and newChar:FindFirstChild("HumanoidRootPart")
            local newBp=Player:FindFirstChild("Backpack")
            for _,tool in ipairs(dropped) do pcall(function()
                if tool and tool.Parent==workspace then
                    if newRoot and tool:FindFirstChild("Handle") then newRoot.CFrame=CFrame.new(tool.Handle.Position+Vector3.new(0,3,0)) end
                    task.wait(.08)
                    if tool.Parent==workspace and newBp then tool.Parent=newBp end
                end
            end) end
            local cnt=newBp and #newBp:GetChildren() or 0
            termPrint("> Cycle done — backpack: "..cnt.." items",T.SUCCESS)
            task.wait(.3)
        end
    end)
end)

